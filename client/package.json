{
  "name": "cortex-client",
  "version": "1.2.0",
  "description": "Düşük gecikmeli P2P sesli/görüntülü sohbet masaüstü uygulaması",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.cortex.voice",
    "productName": "Cortex",
    "icon": "../assets/icon.png",
    "files": [
      "**/*",
      "!**/*.md",
      "!dist/**"
    ],
    "extraResources": [
      {
        "from": "../assets",
        "to": "assets"
      }
    ],
    "asarUnpack": [
      "**/uiohook-napi/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "../assets/icon.png",
      "artifactName": "Cortex-Kurulum.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Cortex",
      "license": "build/license.txt",
      "multiLanguageInstaller": true,
      "installerLanguages": [
        "tr_TR",
        "en_US"
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "../assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "../assets/icon.png"
    }
  },
  "dependencies": {
    "uiohook-napi": "^1.5.5"
  }
}
